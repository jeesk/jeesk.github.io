---
layout: page
---
<!-- Main Content -->
 <h5>最新文章</h5>
<hr>
<% page.posts.each(function(post){ %>
<div class="post-preview">
    
        <li>
            <span><%= post.date.format(config.date_format) %> » </span>
    
            <a href="<%- config.root %><%- post.path %>">
    
                <%- post.title || "Untitled" %>
    
            </a>
        </li>
</div>
<!-- <hr> -->
<% }); %>


<!-- Pager -->

<ul class="pager">
    <% if (page.prev){ %>
        <li class="previous">
            <a href="<%- config.root %><%- page.prev_link %>">&larr; 上一页</a>
        </li>
    <% } %>
    <% if (page.next){ %>
        <li class="next">
            <a href="<%- config.root %><%- page.next_link %>">下一页 &rarr;</a>
        </li>
    <% } %>
</ul>

